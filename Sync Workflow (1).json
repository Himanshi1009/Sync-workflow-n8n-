        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "f9d63ea2-5b5b-4671-9600-0e7698a1f2e1",
      "name": "Get Target Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "kuAfllLTE1evmumL",
          "name": "Header Auth account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const targets = $('Get Target Workflow').all();\nconst preparedItems = $('Prepare Updates').all();\n\nreturn targets.map((targetItem, index) => {\n  const target = targetItem.json;\n  const preparedData = preparedItems[index].json;\n\n  const targetCredentials = {};\n  for (const node of target.nodes || []) {\n    if (node.credentials) {\n      targetCredentials[node.name] = node.credentials;\n    }\n  }\n\n  const masterNodes = preparedData.master_nodes || [];\n  const updatedNodes = masterNodes.map(node => {\n    const updatedNode = { ...node };\n    if (targetCredentials[node.name]) {\n      updatedNode.credentials = targetCredentials[node.name];\n    }\n    return updatedNode;\n  });\n\n  return {\n    json: {\n      target_id: target.id,\n      base_url: preparedData.base_url,\n      updated_workflow: {\n        name: target.name || 'Target Workflow',\n        nodes: updatedNodes,\n        connections: preparedData.master_connections || {},\n        settings: { executionOrder: \"v1\" }\n      }\n    }\n  };\n});"
      },
      "id": "4bfa6ac5-e5e0-4ee3-941d-31d9df783ec8",
      "name": "Merge Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        0
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "={{ $json.base_url }}/api/v1/workflows/{{ $json.target_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.updated_workflow) }}",
        "options": {}
      },
      "id": "30c76160-8704-4e15-b627-397e5905387f",
      "name": "Update Target Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
