        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "kuAfllLTE1evmumL",
          "name": "Header Auth account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const results = $input.all();\nconst success = results.filter(r => r.json.id).length;\nconst failed = results.length - success;\n\nconsole.log(`✅ Successfully updated: ${success} workflows`);\nconsole.log(`❌ Failed: ${failed} workflows`);\n\nreturn [{ json: { success, failed, total: results.length, message: `Sync complete! ${success} workflows updated.` } }];"
      },
